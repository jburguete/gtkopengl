.PHONY: strip clean

FLAGS = -march=native -Os -Wall -Wextra @FONT@
CFLAGS1 = @PNG_CFLAGS@ @FREETYPE_CFLAGS@ @GLIB_CFLAGS@ @GLEW_CFLAGS@ \
	@GTK_CFLAGS@ $(FLAGS)
LDFLAGS1 = -lglut @GTK_LIBS@ @GLEW_LIBS@ @FREETYPE_LIBS@ @PNG_LIBS@ @GLIB_LIBS@
CFLAGS2 = @PNG_CFLAGS@ @FREETYPE_CFLAGS@ @GLIB_CFLAGS@ @GLEW_CFLAGS@ \
	@GTK_CFLAGS@ @GLFW_CFLAGS@ $(FLAGS)
LDFLAGS2 = @GLFW_LIBS@ @GTK_LIBS@ @GLEW_LIBS@ @FREETYPE_LIBS@ @PNG_LIBS@ \
	@GLIB_LIBS@
CFLAGS3 = @PNG_CFLAGS@ @FREETYPE_CFLAGS@ @GLIB_CFLAGS@ @GLEW_CFLAGS@ \
	@GTK_CFLAGS@ @SDL_CFLAGS@ $(FLAGS)
LDFLAGS3 = @SDL_LIBS@ @GTK_LIBS@ @GLEW_LIBS@ @FREETYPE_LIBS@ @PNG_LIBS@ \
	@GLIB_LIBS@
CFLAGS4 = @PNG_CFLAGS@ @FREETYPE_CFLAGS@ @GLIB_CFLAGS@ @GLEW_CFLAGS@ \
	@GTK_CFLAGS@ $(FLAGS)
LDFLAGS4 = @GTK_LIBS@ @GLEW_LIBS@ @FREETYPE_LIBS@ @PNG_LIBS@ @GLIB_LIBS@
CC = gcc -g -flto
SRC = image.c text.c draw.c
HDR = image.h text.h draw.h
ALL = gtk-freeglut gtk-glfw gtk-sdl gtk-glarea

all: $(ALL)

gtk-freeglut: gtk-freeglut.c $(SRC) $(HDR) Makefile
	echo $(FONT)
	$(CC) $(CFLAGS1) gtk-freeglut.c $(SRC) -o gtk-freeglut $(LDFLAGS1)

gtk-glfw: gtk-glfw.c $(SRC) $(HDR) Makefile
	$(CC) $(CFLAGS2) gtk-glfw.c $(SRC) -o gtk-glfw $(LDFLAGS2)

gtk-sdl: gtk-sdl.c $(SRC) $(HDR) Makefile
	$(CC) $(CFLAGS3) gtk-sdl.c $(SRC) -o gtk-sdl $(LDFLAGS3)

gtk-glarea: gtk-glarea.c $(SRC) $(HDR) Makefile
	$(CC) $(CFLAGS4) gtk-glarea.c $(SRC) -o gtk-glarea $(LDFLAGS4)

strip:
	make
	strip $(ALL)

clean:
	rm $(ALL)
