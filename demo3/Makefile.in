.PHONY: strip clean

ifeq (@gtk4@, 1)
ifeq (@freeglut@, 1)
FREEGLUT4 = gtk4-opengl-freeglut
endif
GTK4 = gtk4-opengl-glarea
endif
ifeq (@freeglut@, 1)
FREEGLUT3 = gtk3-opengl-freeglut
endif
GTK3 = gtk3-opengl-glarea

FLAGS = @CFLAGS@ -Os -Wall -Wextra
CFLAGS1 = @PNG_CFLAGS@ @GLIB_CFLAGS@ @GLEW_CFLAGS@ @GLUT_CFLAGS@ $(FLAGS)
LDFLAGS1 = @GLUT_LIBS@ @GLEW_LIBS@ @PNG_LIBS@ @GLIB_LIBS@ @LIBS@ @LDFLAGS@
CFLAGS4 = @PNG_CFLAGS@ @GLIB_CFLAGS@ @GLEW_CFLAGS@ $(FLAGS)
LDFLAGS4 = @GLEW_LIBS@ @PNG_LIBS@ @GLIB_LIBS@ @LIBS@ @LDFLAGS@
CC = @CC@ -g -flto
SRC = draw.c image.c
HDR = draw.h image.h
ALL = $(FREEGLUT3) $(GTK3) \
	$(FREEGLUT4) $(GTK4)

all: $(ALL)
	echo $(ALL)

$(FREEGLUT3): gtk-opengl-freeglut.c $(SRC) $(HDR) Makefile
	$(CC) @GTK3_CFLAGS@ $(CFLAGS1) gtk-opengl-freeglut.c $(SRC) \
		-o $(FREEGLUT3) @GTK3_LIBS@ $(LDFLAGS1)

$(GTK3): gtk-opengl-glarea.c $(SRC) $(HDR) Makefile
	$(CC) @GTK3_CFLAGS@ $(CFLAGS4) gtk-opengl-glarea.c $(SRC) \
		-o $(GTK3) @GTK3_LIBS@ $(LDFLAGS4)

$(FREEGLUT4): gtk-opengl-freeglut.c $(SRC) $(HDR) Makefile
	$(CC) @GTK4_CFLAGS@ $(CFLAGS1) gtk-opengl-freeglut.c $(SRC) \
		-o $(FREEGLUT4) @GTK4_LIBS@ $(LDFLAGS1)

$(GTK4): gtk-opengl-glarea.c $(SRC) $(HDR) Makefile
	$(CC) @GTK4_CFLAGS@ $(CFLAGS4) gtk-opengl-glarea.c $(SRC) \
		-o $(GTK4) @GTK4_LIBS@ $(LDFLAGS4)

strip:
	make
	strip $(ALL)

clean:
	rm $(ALL)
