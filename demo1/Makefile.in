.PHONY: strip clean

GLFW3 = gtk3-opengl-glfw
SDL3 = gtk3-opengl-sdl
GTK3 = gtk3-opengl-glarea
ifeq (@gtk4@, 1)
	FREEGLUT3 = gtk3-opengl-freeglut
	FREEGLUT4 = gtk4-opengl-freeglut
	GLFW4 = gtk4-opengl-glfw
	SDL4 = gtk4-opengl-sdl
	GTK4 = gtk4-opengl-glarea
else
ifeq (@HAIKU@, 0)
	FREEGLUT3 = gtk3-opengl-freeglut
endif
endif

FLAGS = @CFLAGS@ -Os -Wall -Wextra
CFLAGS1 = @GLIB_CFLAGS@ @GLEW_CFLAGS@ @GLUT_CFLAGS@ $(FLAGS)
LDFLAGS1 = @GLUT_LIBS@ @GLEW_LIBS@ @GLIB_LIBS@ @LIBS@ @LDFLAGS@
CFLAGS2 = @GLIB_CFLAGS@ @GLEW_CFLAGS@ @GLFW_CFLAGS@ $(FLAGS)
LDFLAGS2 = @GLFW_LIBS@ @GLEW_LIBS@ @GLIB_LIBS@ @LIBS@ @LDFLAGS@
CFLAGS3 = @GLIB_CFLAGS@ @GLEW_CFLAGS@ @SDL_CFLAGS@ $(FLAGS)
LDFLAGS3 = @SDL_LIBS@ @GLEW_LIBS@ @GLIB_LIBS@ @LIBS@ @LDFLAGS@
CFLAGS4 = @GLIB_CFLAGS@ @GLEW_CFLAGS@ $(FLAGS)
LDFLAGS4 = @GLEW_LIBS@ @GLIB_LIBS@ @LIBS@ @LDFLAGS@
CC = @CC@ -g -flto
SRC = draw.c
HDR = draw.h
ALL = $(FREEGLUT3) $(GLFW3) $(SDL3) $(GTK3) \
	$(FREEGLUT4) $(GLFW4) $(SDL4) $(GTK4)

all: $(ALL)

$(FREEGLUT3): gtk-opengl-freeglut.c $(SRC) $(HDR) Makefile
	$(CC) @GTK3_CFLAGS@ $(CFLAGS1) gtk-opengl-freeglut.c $(SRC) \
		-o $(FREEGLUT3) @GTK3_LIBS@ $(LDFLAGS1)

$(GLFW3): gtk-opengl-glfw.c $(SRC) $(HDR) Makefile
	$(CC) @GTK3_CFLAGS@ $(CFLAGS2) gtk-opengl-glfw.c $(SRC) \
		-o $(GLFW3) @GTK3_LIBS@ $(LDFLAGS2)

$(SDL3): gtk-opengl-sdl.c $(SRC) $(HDR) Makefile
	$(CC) @GTK3_CFLAGS@ $(CFLAGS3) gtk-opengl-sdl.c $(SRC) -o $(SDL3) \
		@GTK3_LIBS@ $(LDFLAGS3)

$(GTK3): gtk-opengl-glarea.c $(SRC) $(HDR) Makefile
	$(CC) @GTK3_CFLAGS@ $(CFLAGS4) gtk-opengl-glarea.c $(SRC) \
		-o $(GTK3) @GTK3_LIBS@ $(LDFLAGS4)

$(FREEGLUT4): gtk-opengl-freeglut.c $(SRC) $(HDR) Makefile
	$(CC) @GTK4_CFLAGS@ $(CFLAGS1) gtk-opengl-freeglut.c $(SRC) \
		-o $(FREEGLUT4) @GTK4_LIBS@ $(LDFLAGS1)

$(GLFW4): gtk-opengl-glfw.c $(SRC) $(HDR) Makefile
	$(CC) @GTK4_CFLAGS@ $(CFLAGS2) gtk-opengl-glfw.c $(SRC) -o $(GLFW4) \
		@GTK4_LIBS@ $(LDFLAGS2)

$(SDL4): gtk-opengl-sdl.c $(SRC) $(HDR) Makefile
	$(CC) @GTK4_CFLAGS@ $(CFLAGS3) gtk-opengl-sdl.c $(SRC) -o $(SDL4) \
		@GTK4_LIBS@ $(LDFLAGS3)

$(GTK4): gtk-opengl-glarea.c $(SRC) $(HDR) Makefile
	$(CC) @GTK4_CFLAGS@ $(CFLAGS4) gtk-opengl-glarea.c $(SRC) \
		-o $(GTK4) @GTK4_LIBS@ $(LDFLAGS4)

strip:
	make
	strip $(ALL)

clean:
	rm $(ALL)
