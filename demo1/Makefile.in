.PHONY: strip clean

FLAGS = -march=native -Os -Wall -Wextra
CFLAGS1 = @GLIB_CFLAGS@ @GLEW_CFLAGS@ $(FLAGS)
LDFLAGS1 = -lglut @GLEW_LIBS@ @GLIB_LIBS@
CFLAGS2 = @GLIB_CFLAGS@ @GLEW_CFLAGS@ @GLFW_CFLAGS@ $(FLAGS)
LDFLAGS2 = @GLFW_LIBS@ @GLEW_LIBS@ @GLIB_LIBS@
CFLAGS3 = @GLIB_CFLAGS@ @GLEW_CFLAGS@ @SDL_CFLAGS@ $(FLAGS)
LDFLAGS3 = @SDL_LIBS@ @GLEW_LIBS@ @GLIB_LIBS@
CFLAGS4 = @GLIB_CFLAGS@ @GLEW_CFLAGS@ $(FLAGS)
LDFLAGS4 = @GLEW_LIBS@ @GLIB_LIBS@
CC = gcc -g -flto
SRC = draw.c
HDR = draw.h
ALL = gtk3-opengl-freeglut gtk3-opengl-glfw gtk3-opengl-sdl gtk3-opengl-glarea \
	gtk4-opengl-freeglut gtk4-opengl-glfw gtk4-opengl-sdl gtk4-opengl-glarea

all: $(ALL)

gtk3-opengl-freeglut: gtk-opengl-freeglut.c $(SRC) $(HDR) Makefile
	$(CC) @GTK3_CFLAGS@ $(CFLAGS1) gtk-opengl-freeglut.c $(SRC) \
		-o gtk3-opengl-freeglut @GTK3_LIBS@ $(LDFLAGS1)

gtk3-opengl-glfw: gtk-opengl-glfw.c $(SRC) $(HDR) Makefile
	$(CC) @GTK3_CFLAGS@ $(CFLAGS2) gtk-opengl-glfw.c $(SRC) \
		-o gtk3-opengl-glfw @GTK3_LIBS@ $(LDFLAGS2)

gtk3-opengl-sdl: gtk-opengl-sdl.c $(SRC) $(HDR) Makefile
	$(CC) @GTK3_CFLAGS@ $(CFLAGS3) gtk-opengl-sdl.c $(SRC) -o gtk3-opengl-sdl \
		@GTK3_LIBS@ $(LDFLAGS3)

gtk3-opengl-glarea: gtk-opengl-glarea.c $(SRC) $(HDR) Makefile
	$(CC) @GTK3_CFLAGS@ $(CFLAGS4) gtk-opengl-glarea.c $(SRC) \
		-o gtk3-opengl-glarea @GTK3_LIBS@ $(LDFLAGS4)

gtk4-opengl-freeglut: gtk-opengl-freeglut.c $(SRC) $(HDR) Makefile
	$(CC) @GTK4_CFLAGS@ $(CFLAGS1) gtk-opengl-freeglut.c $(SRC) \
		-o gtk4-opengl-freeglut @GTK4_LIBS@ $(LDFLAGS1)

gtk4-opengl-glfw: gtk-opengl-glfw.c $(SRC) $(HDR) Makefile
	$(CC) @GTK4_CFLAGS@ $(CFLAGS2) gtk-opengl-glfw.c $(SRC) -o gtk4-opengl-glfw \
		@GTK4_LIBS@ $(LDFLAGS2)

gtk4-opengl-sdl: gtk-opengl-sdl.c $(SRC) $(HDR) Makefile
	$(CC) @GTK4_CFLAGS@ $(CFLAGS3) gtk-opengl-sdl.c $(SRC) -o gtk4-opengl-sdl \
		@GTK4_LIBS@ $(LDFLAGS3)

gtk4-opengl-glarea: gtk-opengl-glarea.c $(SRC) $(HDR) Makefile
	$(CC) @GTK4_CFLAGS@ $(CFLAGS4) gtk-opengl-glarea.c $(SRC) \
		-o gtk4-opengl-glarea @GTK4_LIBS@ $(LDFLAGS4)

strip:
	make
	strip $(ALL)

clean:
	rm $(ALL)
